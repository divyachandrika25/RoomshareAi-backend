# RoomShare AI - Environment Configuration Template
# Copy this file to .env and fill in your actual credentials.

# Django Core Settings
SECRET_KEY=your-django-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,*

# Database Configuration (MySQL/MariaDB)
DB_NAME=roomshare_db
DB_USER=root
DB_PASSWORD=your-db-password
DB_HOST=127.0.0.1
DB_PORT=3306

# Email SMTP Configuration (Gmail recommended)
# For Gmail, use an "App Password" not your regular account password.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password

# Razorpay API Keys (Test or Live)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

# Mistral AI (Cloud Fallback)
MISTRAL_API_KEY=your_mistral_api_key_here

# Asset URLs
MEDIA_URL=/media/
STATIC_URL=static/
